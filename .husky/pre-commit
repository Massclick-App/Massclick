#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# CSS Module Isolation Check
# Prevents new CSS leakage from being committed

echo "🎨 Checking CSS Modules for leakage..."

# Check for new descendant selectors (> .classname pattern)
DESCENDANT_ERRORS=$(git diff --staged --name-only --diff-filter=ACM | grep "\.module\.css$" | xargs -I {} git diff --staged {} | grep -E "^\+.*> \." | grep -v "/\*" | wc -l)

if [ "$DESCENDANT_ERRORS" -gt 0 ]; then
  echo "❌ ERROR: New descendant selectors detected in CSS modules!"
  echo "   CSS Modules must NOT target child components."
  echo "   See: src/styles/CSS_MODULES_GUIDELINES.md"
  exit 1
fi

# Check for suspicious new !important (allow with explanation comment)
IMPORTANT_LINES=$(git diff --staged --name-only --diff-filter=ACM | grep "\.module\.css$" | xargs -I {} git diff --staged {} | grep "^\+.*!important" | wc -l)
IMPORTANT_WITH_COMMENTS=$(git diff --staged --name-only --diff-filter=ACM | grep "\.module\.css$" | xargs -I {} git diff --staged {} | grep -B1 "^\+.*!important" | grep "/\*" | wc -l)

if [ "$IMPORTANT_LINES" -gt "$IMPORTANT_WITH_COMMENTS" ]; then
  echo "⚠️  WARNING: New !important declaration without explanation comment"
  echo "   If this is necessary, add a comment explaining why."
  echo "   Example: /* !important because: overrides form library MUI margin */"
  echo "   Continue with: git commit --no-verify"
  exit 0
fi

echo "✅ CSS Modules check passed!"
exit 0
