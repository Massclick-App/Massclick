<IfModule mod_expires.c>
  ExpiresActive On

  # Images: cache for 30 days
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"

  # JavaScript & CSS: cache for 1 year (with hash-based busting)
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"

  # HTML: no cache (always check server)
  ExpiresByType text/html "access plus 0 seconds"

  # Default: 30 days
  ExpiresDefault "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
  # Images: strong cache
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>

  # Fonts: strong cache
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # JS/CSS bundles with hash: strong cache
  <FilesMatch "\.[a-f0-9]{8,}\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML & main JS: revalidate always
  <FilesMatch "^index\.html$|\.html$|^service-worker\.js$">>
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
